{
  "version": 2,
  "buildCommand": "",
  "outputDirectory": ".",
  "installCommand": "echo skip",
  "framework": null,
  "routes": [
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/login",
      "dest": "/login.html"
    },
    {
      "src": "/dashboard",
      "dest": "/dashboard.html"
    },
    {
      "src": "/loan",
      "dest": "/loan.html"
    },
    {
      "src": "/payment",
      "dest": "/payment.html"
    },
    {
      "src": "/contact",
      "dest": "/contact.html"
    },
    {
      "src": "/faq",
      "dest": "/faq.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}